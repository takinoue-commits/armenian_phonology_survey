                            </div>
                        </div>

                        <div className="space-y-2">
                            {sentences.map((item) => (
                                <RecordingItem 
                                    key={item.id} 
                                    item={item} 
                                    onSaveAudio={saveAudio} 
                                    savedAudioUrl={audioBlobs[item.id] ? URL.createObjectURL(audioBlobs[item.id]) : null}
                                />
                            ))}
                        </div>

                        <div className="mt-12 bg-white rounded-xl shadow-lg p-8 border border-gray-100 text-center">
                            <h2 className="text-2xl font-bold text-gray-800 mb-4">Submit Session Data</h2>
                            <p className="text-gray-600 mb-6">Once all recordings are complete, please click the button below to submit your data to the researcher's Google Drive.</p>
                            
                            {uploadStatus.message && (
                                <div className={`mb-6 p-4 rounded-lg font-medium text-left ${uploadStatus.type === 'error' ? 'bg-red-50 text-red-700 border border-red-200' : uploadStatus.type === 'success' ? 'bg-green-50 text-green-700 border border-green-200' : 'bg-blue-50 text-blue-700 border border-blue-200'}`}>
                                    {uploadStatus.message}
                                </div>
                            )}

                            <button 
                                onClick={submitToDrive}
                                disabled={isUploading || recordedCount === 0}
                                className={`px-8 py-4 rounded-full font-bold text-lg text-white shadow-lg transition-all flex items-center justify-center gap-3 mx-auto ${isUploading || recordedCount === 0 ? 'bg-gray-400 cursor-not-allowed' : 'bg-green-600 hover:bg-green-700 hover:shadow-xl hover:-translate-y-1'}`}
                            >
                                {isUploading ? (
                                    <><i className="fas fa-spinner fa-spin"></i> Processing & Sending ({uploadProgress}%)</>
                                ) : (
                                    <><i className="fab fa-google-drive"></i> Submit to Drive</>
                                )}
                            </button>
                        </div>
                    </div>
                </div>
            );
        };

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
</body>
</html>
