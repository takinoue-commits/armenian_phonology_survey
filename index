                gender: '',
                city: '',
                country: '',
                dialect: '',
                nativeLanguage: '',
                otherLanguages: '',
                yearsOutside: '',
                speechDisorder: ''
            });

            const [audioBlobs, setAudioBlobs] = React.useState({});
            const [isUploading, setIsUploading] = React.useState(false);
            const [uploadProgress, setUploadProgress] = React.useState(0);
            const [uploadStatus, setUploadStatus] = React.useState({ type: '', message: '' });

            const recordedCount = Object.keys(audioBlobs).length;
            const progressPercentage = Math.round((recordedCount / sentences.length) * 100);

            const handleDemoChange = (e) => {
                setDemographics({ ...demographics, [e.target.name]: e.target.value });
            };

            const saveAudio = (id, blob) => {
                setAudioBlobs(prev => ({ ...prev, [id]: blob }));
            };

            const submitToDrive = async () => {
                if (!demographics.participantId) {
                    alert("Participant ID is required.");
                    return;
                }
                if (recordedCount === 0) {
                    alert("No recordings found.");
                    return;
                }
                if (GAS_WEB_APP_URL === "YOUR_GAS_WEB_APP_URL_HERE") {
                    alert("Error: Please set GAS_WEB_APP_URL in the source code.");
                    return;
                }

                setIsUploading(true);
                setUploadStatus({ type: 'info', message: 'Converting to WAV and creating ZIP...' });
                setUploadProgress(10);

                try {
                    const zip = new JSZip();
                    const partId = demographics.participantId.replace(/[^a-z0-9]/gi, '_');

                    const conversionPromises = Object.entries(audioBlobs).map(async ([id, blob]) => {
                        try {
                            const wavBlob = await convertToWav(blob);
                            zip.file(`${partId}_item_${id.padStart(2, '0')}.wav`, wavBlob);
                        } catch (e) {
                            console.error("WAV conversion failed for id", id, e);
                            zip.file(`${partId}_item_${id.padStart(2, '0')}_fallback.webm`, blob);
                        }
                    });

                    await Promise.all(conversionPromises);
                    setUploadProgress(40);

                    const demoText = `
=== Participant Demographics ===
ID: ${demographics.participantId}
Year of Birth: ${demographics.birthYear}
Gender: ${demographics.gender}
City: ${demographics.city}
Country: ${demographics.country}
Dialect: ${demographics.dialect}
Native Language: ${demographics.nativeLanguage}
Other Languages: ${demographics.otherLanguages}
Years outside home: ${demographics.yearsOutside}
Speech Disorder: ${demographics.speechDisorder}
================================
                    `;
                    zip.file(`${partId}_demographics.txt`, demoText);

                    setUploadStatus({ type: 'info', message: 'Compressing data...' });
                    const zipBlob = await zip.generateAsync({ type: 'blob' });
                    setUploadProgress(70);

                    const base64Data = await blobToBase64(zipBlob);

                    setUploadStatus({ type: 'info', message: 'Sending to Google Drive...' });
                    
                    const payload = {
                        filename: `${partId}_audio_data.zip`,
                        mimeType: 'application/zip',
                        data: base64Data
                    };

                    const response = await fetch(GAS_WEB_APP_URL, {
                        method: 'POST',
                        body: JSON.stringify(payload),
                        headers: { 'Content-Type': 'text/plain' } 
                    });

                    const result = await response.json();

                    if (result.success) {
                        setUploadProgress(100);
                        setUploadStatus({ type: 'success', message: '✅ Successfully sent to Google Drive! Thank you for your cooperation.' });
                    } else {
                        throw new Error(result.error);
                    }

                } catch (error) {
                    console.error("Upload error:", error);
                    setUploadStatus({ type: 'error', message: `❌ Upload Error: ${error.message}` });
                } finally {
                    setIsUploading(false);
                }
            };

