                                <p>Contact: <a href="mailto:takinoue@pep-rg.jp" className="text-blue-400 hover:underline">takinoue@pep-rg.jp</a></p>
                            </div>

                            <div className="mt-8 bg-slate-700/50 rounded-xl p-6 border border-slate-600">
                                <h2 className="text-xl font-semibold mb-4 text-blue-300"><i className="fas fa-user-circle mr-2"></i>Demographic Questionnaire</h2>
                                <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                                    <div>
                                        <label className="block text-sm text-slate-300 mb-1">Participant ID / Code (Required)*</label>
                                        <input type="text" name="participantId" value={demographics.participantId} onChange={handleDemoChange} className="w-full bg-slate-800 border border-slate-600 rounded px-3 py-2 text-white focus:outline-none focus:border-blue-500" placeholder="e.g. P001" required />
                                    </div>
                                    <div>
                                        <label className="block text-sm text-slate-300 mb-1">Year of Birth (Ծննդյան տարեթիվ)</label>
                                        <input type="text" name="birthYear" value={demographics.birthYear} onChange={handleDemoChange} className="w-full bg-slate-800 border border-slate-600 rounded px-3 py-2 text-white focus:outline-none focus:border-blue-500" placeholder="YYYY" />
                                    </div>
                                    <div>
                                        <label className="block text-sm text-slate-300 mb-1">Gender (Սեռ)</label>
                                        <select name="gender" value={demographics.gender} onChange={handleDemoChange} className="w-full bg-slate-800 border border-slate-600 rounded px-3 py-2 text-white focus:outline-none focus:border-blue-500">
                                            <option value="">Select...</option>
                                            <option value="Male">Male (Արական)</option>
                                            <option value="Female">Female (Իգական)</option>
                                            <option value="Prefer not to say">Prefer not to say</option>
                                        </select>
                                    </div>
                                    <div>
                                        <label className="block text-sm text-slate-300 mb-1">Armenian Dialect (Արևելահայերեն թե՞...)</label>
                                        <select name="dialect" value={demographics.dialect} onChange={handleDemoChange} className="w-full bg-slate-800 border border-slate-600 rounded px-3 py-2 text-white focus:outline-none focus:border-blue-500">
                                            <option value="">Select...</option>
                                            <option value="Eastern">Eastern (e.g. Armenia, Iran)</option>
                                            <option value="Western">Western (e.g. Lebanon, Syria)</option>
                                        </select>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div className="max-w-4xl mx-auto px-4 -mt-8 relative z-10">
                        <div className="bg-white rounded-xl shadow-lg p-6 mb-8 border border-gray-100">
                            <div className="flex justify-between items-end mb-2">
